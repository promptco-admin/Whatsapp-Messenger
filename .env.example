# WhatsApp Cloud API credentials (from Meta Business / developers.facebook.com)
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_API_VERSION=v21.0

# Webhook verification token — any random string, must match what you set in Meta App Dashboard
WHATSAPP_WEBHOOK_VERIFY_TOKEN=pick-a-random-string

# Meta App Secret — used to verify webhook payload signatures
WHATSAPP_APP_SECRET=your_app_secret_here

# SQLite database file path (absolute or relative to project root)
DATABASE_PATH=./data/messenger.db
